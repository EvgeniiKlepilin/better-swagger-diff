{
  "openapi": "3.0.3",
  "info": {
    "title": "Circular Ref API",
    "description": "Tests that circular $refs do not cause infinite recursion",
    "version": "1.0.0"
  },
  "paths": {
    "/nodes": {
      "get": {
        "summary": "Get a tree node",
        "operationId": "getNode",
        "responses": {
          "200": {
            "description": "A tree node with optional children",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TreeNode" }
              }
            }
          }
        }
      }
    },
    "/categories": {
      "get": {
        "summary": "Get a category tree",
        "operationId": "getCategories",
        "responses": {
          "200": {
            "description": "Root category",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Category" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TreeNode": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "value": { "type": "string" },
          "children": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TreeNode" }
          }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "parent": { "$ref": "#/components/schemas/Category" },
          "subcategories": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Category" }
          }
        }
      }
    }
  }
}
