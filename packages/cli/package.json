{
  "name": "@better-swagger-diff/cli",
  "version": "0.1.0",
  "description": "CLI for Better Swagger Diff",
  "type": "module",
  "bin": {
    "bsd": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "build:bin": "pnpm build:bin:darwin-arm64 && pnpm build:bin:darwin-x64 && pnpm build:bin:linux-x64 && pnpm build:bin:linux-arm64 && pnpm build:bin:windows-x64",
    "build:bin:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 src/index.ts --outfile binaries/bsd-darwin-arm64",
    "build:bin:darwin-x64": "bun build --compile --target=bun-darwin-x64 src/index.ts --outfile binaries/bsd-darwin-x64",
    "build:bin:linux-x64": "bun build --compile --target=bun-linux-x64 src/index.ts --outfile binaries/bsd-linux-x64",
    "build:bin:linux-arm64": "bun build --compile --target=bun-linux-arm64 src/index.ts --outfile binaries/bsd-linux-arm64",
    "build:bin:windows-x64": "bun build --compile --target=bun-windows-x64 src/index.ts --outfile binaries/bsd-windows-x64.exe",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist binaries"
  },
  "dependencies": {
    "@better-swagger-diff/core": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "eslint": "^10.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^2.1.0"
  }
}
